# Puerto donde escucha el servidor
PORT=3000

# URL completa del webhook en tu Laravel
LARAVEL_WEBHOOK_URL=https://tu-laravel-dominio.com/api/whatsapp/webhook-from-vps

# Debe coincidir exactamente con WEBHOOK_SECRET del .env de Laravel
WEBHOOK_SECRET=30d17d50d2c1061a0e513bf3e97773f942060764d24aae4c92d65753b63094d7

# true  → inicia WhatsApp automáticamente al arrancar el servidor
#         (útil si ya tienes sesión guardada de una conexión anterior)
# false → espera a recibir POST /request-qr
AUTO_INIT=false
